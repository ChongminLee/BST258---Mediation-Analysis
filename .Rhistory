1+1
# Load necessary library
library(dplyr)
# Set seed for reproducibility
set.seed(258)
# Define sample size
n <- 100000
# 1. Generate the Unmeasured Confounder (U)
# Represents baseline health or socioeconomic factors
U <- rnorm(n, mean = 0, sd = 1)
# 2. Simulate Exposure (A) and Clinic Access (S)
# A: Randomized into the study
A <- rbinom(n, size = 1, prob = 0.5)
# S: Access to the clinic (S=1 iff A=1)
S <- A
# 3. Simulate Counterfactual and Observed Mediator (M: Ivermectin)
# M(a=0) depends on U (e.g., self-treatment behavior)
M_a0 <- rbinom(n, size = 1, prob = plogis(0.5 * U))
# M(a=1) is randomized by investigators, independent of U
M_a1 <- rbinom(n, size = 1, prob = 0.5)
# Observed M
M <- ifelse(A == 1, M_a1, M_a0)
# 4. Simulate Counterfactual and Observed Immunosuppression (R)
# If S=0 (no clinic access), R=0 deterministically
R_s0_m0 <- rep(0, n)
R_s0_m1 <- rep(0, n)
# If S=1 (clinic access), R depends on taking Ivermectin (M) and confounder (U)
R_s1_m0 <- rbinom(n, size = 1, prob = plogis(-1 + 0.5 * U))
R_s1_m1 <- rbinom(n, size = 1, prob = plogis( 1 + 0.5 * U))
# Observed R
R <- case_when(
A == 0 & M == 0 ~ R_s0_m0,
A == 0 & M == 1 ~ R_s0_m1,
A == 1 & M == 0 ~ R_s1_m0,
A == 1 & M == 1 ~ R_s1_m1
)
# 5. Simulate Counterfactual and Observed Outcome (Y: River Blindness)
# Y depends on M, R, and U.
# We use a continuous outcome for simplicity in expectation calculations.
generate_Y <- function(r, m, u) {
rnorm(length(u), mean = 5 + 2 * m + 3 * r + 1.5 * u, sd = 1)
}
# Counterfactual outcomes under specific interventions
# Y(a=1, m=0) -> implies S=1, M=0, so R = R_s1_m0
Y_a1_m0 <- generate_Y(r = R_s1_m0, m = rep(0, n), u = U)
# Y(a=0, m=0) -> implies S=0, M=0, so R = R_s0_m0
Y_a0_m0 <- generate_Y(r = R_s0_m0, m = rep(0, n), u = U)
# Observed Y
Y <- generate_Y(r = R, m = M, u = U)
# ==========================================
# ANALYSIS & PROOF OF CONCEPT
# ==========================================
cat("--- Testing Cross-World Independence ---\n")
# Disproving Y(a=1, m=0) is independent of M(a=0)
# Y_a1_m0 depends on U (via R_s1_m0 and directly), and M_a0 depends on U.
correlation <- cor(Y_a1_m0, M_a0)
cat("Correlation between Y(a=1, m=0) and M(a=0):", round(correlation, 4), "\n")
cat("Since the correlation is non-zero, Cross-World Independence is violated.\n\n")
cat("--- Estimating the Pure Direct Effect (PDE) ---\n")
# 1. Calculate the TRUE PDE from counterfactuals
# PDE = E[Y(a=1, M(a=0))] - E[Y(a=0, M(a=0))]
# Calculate Y(a=1, M(a=0)): Requires R under a=1 but natural M(0)
R_a1_Ma0 <- ifelse(M_a0 == 1, R_s1_m1, R_s1_m0)
Y_a1_Ma0 <- generate_Y(r = R_a1_Ma0, m = M_a0, u = U)
# Calculate Y(a=0, M(a=0)): Requires R under a=0 but natural M(0)
R_a0_Ma0 <- ifelse(M_a0 == 1, R_s0_m1, R_s0_m0)
Y_a0_Ma0 <- generate_Y(r = R_a0_Ma0, m = M_a0, u = U)
true_PDE <- mean(Y_a1_Ma0 - Y_a0_Ma0)
cat("True PDE (from unobservable counterfactuals):", round(true_PDE, 4), "\n")
# 2. Naive Mediation Formula Estimate
# Assumes Cross-World Independence holds: \sum_m E[Y | a=1, m] * P(M=m | a=0) - E[Y | a=0]
E_Y_a1_m0 <- mean(Y[A == 1 & M == 0])
E_Y_a1_m1 <- mean(Y[A == 1 & M == 1])
P_m0_a0 <- mean(M[A == 0] == 0)
P_m1_a0 <- mean(M[A == 0] == 1)
E_Y_a0 <- mean(Y[A == 0])
naive_PDE <- (E_Y_a1_m0 * P_m0_a0 + E_Y_a1_m1 * P_m1_a0) - E_Y_a0
cat("Naive PDE (using Mediation Formula):        ", round(naive_PDE, 4), "\n")
# 3. Bias calculation
cat("Bias induced by intermediate confounding:    ", round(naive_PDE - true_PDE, 4), "\n")
# Load necessary library
library(dplyr)
# Set seed for reproducibility
set.seed(258)
# Define sample size
n <- 100000
# 1. Generate the Unmeasured Confounder (U)
# Represents baseline health or socioeconomic factors
U <- rnorm(n, mean = 0, sd = 1)
# 2. Simulate Exposure (A) and Clinic Access (S)
# A: Randomized into the study
A <- rbinom(n, size = 1, prob = 0.5)
# S: Access to the clinic (S=1 iff A=1)
S <- A
# 3. Simulate Counterfactual and Observed Mediator (M: Ivermectin)
# M(a=0) depends on U (e.g., self-treatment behavior)
M_a0 <- rbinom(n, size = 1, prob = plogis(0.5 * U))
# M(a=1) is randomized by investigators, independent of U
M_a1 <- rbinom(n, size = 1, prob = 0.5)
# Observed M
M <- ifelse(A == 1, M_a1, M_a0)
# 4. Simulate Counterfactual and Observed Immunosuppression (R)
# If S=0 (no clinic access), R=0 deterministically
R_s0_m0 <- rep(0, n)
R_s0_m1 <- rep(0, n)
# If S=1 (clinic access), R depends on taking Ivermectin (M) and confounder (U)
R_s1_m0 <- rbinom(n, size = 1, prob = plogis(-1 + 0.5 * U))
R_s1_m1 <- rbinom(n, size = 1, prob = plogis( 1 + 0.5 * U))
# Observed R
R <- case_when(
A == 0 & M == 0 ~ R_s0_m0,
A == 0 & M == 1 ~ R_s0_m1,
A == 1 & M == 0 ~ R_s1_m0,
A == 1 & M == 1 ~ R_s1_m1
)
# 5. Simulate Counterfactual and Observed Outcome (Y: River Blindness)
# Y depends on M, R, and U.
# We use a continuous outcome for simplicity in expectation calculations.
generate_Y <- function(r, m, u) {
rnorm(length(u), mean = 5 + 2 * m + 3 * r + 1.5 * u, sd = 1)
}
# Counterfactual outcomes under specific interventions
# Y(a=1, m=0) -> implies S=1, M=0, so R = R_s1_m0
Y_a1_m0 <- generate_Y(r = R_s1_m0, m = rep(0, n), u = U)
# Y(a=0, m=0) -> implies S=0, M=0, so R = R_s0_m0
Y_a0_m0 <- generate_Y(r = R_s0_m0, m = rep(0, n), u = U)
# Observed Y
Y <- generate_Y(r = R, m = M, u = U)
# ==========================================
# ANALYSIS & PROOF OF CONCEPT
# ==========================================
cat("--- Testing Cross-World Independence ---\n")
# Disproving Y(a=1, m=0) is independent of M(a=0)
# Y_a1_m0 depends on U (via R_s1_m0 and directly), and M_a0 depends on U.
correlation <- cor(Y_a1_m0, M_a0)
cat("Correlation between Y(a=1, m=0) and M(a=0):", round(correlation, 4), "\n")
cat("Since the correlation is non-zero, Cross-World Independence is violated.\n\n")
cat("--- Estimating the Pure Direct Effect (PDE) ---\n")
# 1. Calculate the TRUE PDE from counterfactuals
# PDE = E[Y(a=1, M(a=0))] - E[Y(a=0, M(a=0))]
# Calculate Y(a=1, M(a=0)): Requires R under a=1 but natural M(0)
R_a1_Ma0 <- ifelse(M_a0 == 1, R_s1_m1, R_s1_m0)
Y_a1_Ma0 <- generate_Y(r = R_a1_Ma0, m = M_a0, u = U)
# Calculate Y(a=0, M(a=0)): Requires R under a=0 but natural M(0)
R_a0_Ma0 <- ifelse(M_a0 == 1, R_s0_m1, R_s0_m0)
Y_a0_Ma0 <- generate_Y(r = R_a0_Ma0, m = M_a0, u = U)
true_PDE <- mean(Y_a1_Ma0 - Y_a0_Ma0)
cat("True PDE (from unobservable counterfactuals):", round(true_PDE, 4), "\n")
# 2. Naive Mediation Formula Estimate
# Assumes Cross-World Independence holds: \sum_m E[Y | a=1, m] * P(M=m | a=0) - E[Y | a=0]
E_Y_a1_m0 <- mean(Y[A == 1 & M == 0])
E_Y_a1_m1 <- mean(Y[A == 1 & M == 1])
P_m0_a0 <- mean(M[A == 0] == 0)
P_m1_a0 <- mean(M[A == 0] == 1)
E_Y_a0 <- mean(Y[A == 0])
naive_PDE <- (E_Y_a1_m0 * P_m0_a0 + E_Y_a1_m1 * P_m1_a0) - E_Y_a0
cat("Naive PDE (using Mediation Formula):        ", round(naive_PDE, 4), "\n")
# 3. Bias calculation
cat("Bias induced by intermediate confounding:    ", round(naive_PDE - true_PDE, 4), "\n")
# Load ggplot2 and tidyr for visualization
library(ggplot2)
library(tidyr)
# ---------------------------------------------------------
# PLOT 1: Visualizing the Cross-World Independence Violation
# ---------------------------------------------------------
# Create a dataframe for the counterfactuals
df_crossworld <- data.frame(
Y_a1_m0 = Y_a1_m0,
M_a0 = as.factor(M_a0)
)
plot1 <- ggplot(df_crossworld, aes(x = M_a0, y = Y_a1_m0, fill = M_a0)) +
geom_boxplot(alpha = 0.7, outlier.alpha = 0.1) +
scale_fill_manual(values = c("skyblue", "salmon")) +
labs(
title = "Violation of Cross-World Independence",
subtitle = paste("Correlation =", round(cor(Y_a1_m0, M_a0), 4)),
x = "Counterfactual Mediator M(a=0)\n(Natural Ivermectin Use)",
y = "Counterfactual Outcome Y(a=1, m=0)\n(Outcome under Clinic Access but No Ivermectin)"
) +
theme_minimal() +
theme(legend.position = "none")
print(plot1)
# ---------------------------------------------------------
# PLOT 2: True Individual PDEs vs. Average Estimates
# ---------------------------------------------------------
# Calculate the individual-level True Pure Direct Effect
individual_PDE <- Y_a1_Ma0 - Y_a0_Ma0
df_pde <- data.frame(PDE = individual_PDE)
plot2 <- ggplot(df_pde, aes(x = PDE)) +
geom_density(fill = "lightgray", alpha = 0.5, color = "darkgray") +
geom_vline(aes(xintercept = true_PDE, color = "True Average PDE"),
linetype = "solid", size = 1.2) +
geom_vline(aes(xintercept = naive_PDE, color = "Naive Estimate (Mediation Formula)"),
linetype = "dashed", size = 1.2) +
scale_color_manual(name = "Estimates",
values = c("True Average PDE" = "black",
"Naive Estimate (Mediation Formula)" = "red")) +
labs(
title = "Distribution of Individual Pure Direct Effects",
subtitle = "Comparing the True Average PDE to the Biased Naive Estimate",
x = "Individual Pure Direct Effect: Y(a=1, M(a=0)) - Y(a=0, M(a=0))",
y = "Density"
) +
theme_minimal() +
theme(legend.position = "bottom")
print(plot2)
