theme(
axis.text = element_text(color = "black"),
axis.title = element_text(color = "black")
)
library(ggplot2)
# Keep your original data so the visual shape is completely identical
df <- data.frame(
x = c(0, 1000, 8000),
y = c(28.0, 30.0, 19.5)
)
ggplot(df, aes(x = x, y = y)) +
# Dash line down to the bottom (y = 19 is our bottom axis limit)
geom_segment(aes(x = 1000, y = 30, xend = 1000, yend = 19), linetype = "dashed") +
geom_line(linewidth = 1.2) +
# THE FIX: Keep a standard continuous scale so the peak still points UP,
# but manually assign reversed labels to the normal breaks.
scale_y_continuous(
limits = c(19, 31),
breaks = c(20.0, 22.5, 25.0, 27.5, 30.0),
# The physical bottom of the graph (20) gets labeled "30.0"
# The physical top of the graph (30) gets labeled "20.0"
labels = c("30.0", "27.5", "25.0", "22.5", "20.0")
) +
# Standard x-axis
scale_x_continuous(
breaks = c(0, 1000, 2000, 3000, 4000, 5000, 6000, 7000, 8000),
labels = c("0", "q = t*", "2000", "3000", "4000", "5000", "6000", "7000", "8000")
) +
# Annotation naturally sits above the physical peak of 30
annotate("text", x = 1000, y = 30.5, label = "t* = 1000 Hz", size = 5) +
labs(
x = "Frequency (Hz)",
y = "Hearing Threshold (dB)"
) +
theme_classic(base_size = 14) +
theme(
axis.text = element_text(color = "black"),
axis.title = element_text(color = "black")
)
